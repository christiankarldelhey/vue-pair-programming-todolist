    "clsx": "^2.1.1",
    "lucide-react": "^1.26.0",
    "lucide-vue-next": "^1.0.0",
    "reka-ui": "^2.10.1",
    "shadcn": "^4.14.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.3",
    "@types/node": "^26.1.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/tsconfig": "^0.8.1",
    "sass-embedded": "^1.98.0",
